# Fireworks AI API credentials
FIREWORKS_API_KEY=your_fireworks_api_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# Hugging Face Token (if pulling model weights locally)
HF_TOKEN=your_hugging_face_token_here

# Local vLLM Inference Config
LOCAL_VLLM_URL=http://localhost:8000/v1
LOCAL_MODEL=google/gemma-3-4b-it
REMOTE_MODEL=gemma-3-27b-it

# Cascade Orchestration Settings
CACHE_SIMILARITY_THRESHOLD=0.96
ESCALATION_THRESHOLD=0.72
SELF_CONSISTENCY_N=3
SELF_REFINE_ROUNDS=1
MAX_MODEL_LEN=8192
GPU_MEMORY_UTILIZATION=0.85

# Mock LLM (set True to simulate local and remote inference without GPUs or API costs)
MOCK_LLM=True
SIMULATE_LOCAL=True
